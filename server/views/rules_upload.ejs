<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Upload Rules · Mitre Agent</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="topbar">
    <a class="brand" href="/rules/upload">Mitre Agent</a>
    <div class="right">
      <span class="badge"><%= user.role %></span>
      <a href="/" style="color: var(--text-dim); text-decoration: none; font-size: 13px;">Back to app</a>
      <form class="inline" method="POST" action="/logout">
        <button class="btn btn-ghost" type="submit">Log out</button>
      </form>
    </div>
  </div>

  <div class="page">
    <h1>Upload Detection Rules</h1>
    <p class="lead">Upload a CSV exported from Splunk to map your rules to ATT&amp;CK techniques.</p>

    <% if (error) { %>
      <div class="error-banner"><%= error %></div>
    <% } %>

    <div class="card">
      <form method="POST" action="/rules/upload" enctype="multipart/form-data">
        <div class="field">
          <label for="csv">CSV file</label>
          <input type="file" id="csv" name="csv" accept=".csv,text/csv" required />
        </div>
        <button class="btn" type="submit">Upload &amp; Analyze</button>
      </form>
    </div>

    <div class="card" style="margin-top: 20px;">
      <h3 style="margin-top:0; color: var(--accent); font-size: 14px;">Expected columns</h3>
      <p style="color: var(--text-dim); font-size: 13px; margin-bottom: 8px;">
        <code>no</code>, <code>rule_name</code>, <code>description</code>, <code>query</code>,
        <code>cron</code>, <code>timerange</code>, <code>applicable_datasource</code>
      </p>
      <p style="color: var(--text-dim); font-size: 12px; margin: 0;">
        <code>rule_name</code> and <code>query</code> are required; the rest are optional but improve match quality.
        <code>applicable_datasource</code> should list platforms (e.g. "Windows, Linux") -- it scopes which
        platforms count toward coverage for your environment.
      </p>
    </div>
  </div>
</body>
</html>
