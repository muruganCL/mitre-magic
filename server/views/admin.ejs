<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Settings · Mitre Agent</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="topbar">
    <a class="brand" href="/rules/upload">Mitre Agent</a>
    <div class="right">
      <span class="badge"><%= user.role %></span>
      <a href="/" style="color: var(--text-dim); text-decoration: none; font-size: 13px;">Back to app</a>
      <form class="inline" method="POST" action="/logout">
        <button class="btn btn-ghost" type="submit">Log out</button>
      </form>
    </div>
  </div>

  <div class="page">
    <h1>Admin Settings</h1>
    <p class="lead">Signed in as <%= user.username %> &middot; admin backend</p>

    <div class="card">
      <div class="settings-grid">
        <a class="settings-item settings-link" href="/admin/prompts">
          <h3>Agent Prompts</h3>
          <p>Review and edit the system prompts for the Detection Profile, Technique Mapping, and QA agents. Versioned.</p>
        </a>
        <div class="settings-item">
          <h3>LLM Provider</h3>
          <p>Configure the Pix gateway endpoint and default model used by jobs.</p>
        </div>
        <div class="settings-item">
          <h3>User Management</h3>
          <p>Create, disable, or promote user accounts.</p>
        </div>
        <div class="settings-item">
          <h3>Database</h3>
          <p>Connection status and retention settings for mitre-postgres.</p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
